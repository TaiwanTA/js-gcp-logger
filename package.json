{
  "name": "@taiwanta/js-gcp-logger",
  "version": "0.3.1",
  "description": "Zero-config GCP logger integration with loglayer",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./middleware/hono": {
      "import": "./dist/middleware/hono/index.js",
      "types": "./dist/middleware/hono/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsdown",
    "test": "bun test",
    "test:watch": "bun test --watch",
    "lint": "tsc --noEmit",
    "prepublishOnly": "bun run build"
  },
  "keywords": [],
  "author": "",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/TaiwanTA/js-gcp-logger.git"
  },
  "publishConfig": {
    "registry": "https://registry.npmjs.org",
    "access": "public"
  },
  "dependencies": {
    "@loglayer/transport-simple-pretty-terminal": "^3.0.0",
    "loglayer": "^9.0.0",
    "serialize-error": "^13.0.1"
  },
  "devDependencies": {
    "@types/bun": "^1.3.10",
    "hono": "^4.11.3",
    "tsdown": "^0.11.13",
    "typescript": "^5.7.0"
  },
  "peerDependencies": {
    "hono": "^4.0.0"
  },
  "peerDependenciesMeta": {
    "hono": {
      "optional": true
    }
  },
  "engines": {
    "node": ">=18"
  }
}
